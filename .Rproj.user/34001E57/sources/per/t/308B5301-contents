# Tidying a Recipe with `tidy()`

## The full Ames recipe

```{r full-ames-recipe}
ames_rec <-
  recipe(
    Sale_Price ~ Neighborhood +
      Gr_Liv_Area +
      Year_Built +
      Bldg_Type +
      Latitude +
      Longitude,
    data = ames_train
  ) %>%
  step_log(Gr_Liv_Area, base = 10) %>%
  step_other(Neighborhood, threshold = 0.01, id = "nbhd_other") %>%
  step_dummy(all_nominal_predictors()) %>%
  step_interact(~ Gr_Liv_Area:starts_with("Bldg_Type_")) %>%
  step_ns(Latitude, Longitude, deg_free = 20)
```

## Inspect the step registry

```{r tidy-recipe-untrained}
tidy(ames_rec)
```

## Train and inspect learned parameters

```{r fit-full-workflow}
lm_wflow <-
  workflow() %>%
  add_model(lm_model) %>%
  add_recipe(ames_rec)

lm_fit <- fit(lm_wflow, ames_train)

estimated_rec <- extract_recipe(lm_fit, estimated = TRUE)
```

```{r tidy-by-id}
# Which neighborhoods were retained (not pooled into 'other')?
tidy(estimated_rec, id = "nbhd_other")
```

```{r tidy-by-number}
# Same result using step number
tidy(estimated_rec, number = 2)
```

```{r tidy-step-count}
# How many retained neighborhoods?
tidy(estimated_rec, id = "nbhd_other") %>%
  count()
```

