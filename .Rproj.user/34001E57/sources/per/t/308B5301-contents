## Exercise 3 — Spline Degrees of Freedom Comparison

The chapter warns that too few spline terms underfit while too many
overfit.

a.  Fit three separate workflows using `step_ns(Latitude, deg_free = d)`
    for `d` in `c(5, 20, 50)`.
b.  For each, compute RMSE on the **test set**.
c.  Plot predicted vs. actual for each. Which degrees of freedom gives
    the best test-set performance?
d.  Why shouldn't you select `deg_free` purely based on test-set RMSE?
    What should you use instead? (Hint: Chapter 10.)

```{r ex3-solution}
#| code-fold: true
#| code-summary: "Show solution"
#| eval: false
#| echo: false
make_spline_wflow <- function(df) {
  rec <- recipe(
    Sale_Price ~ Neighborhood +
      Gr_Liv_Area +
      Year_Built +
      Bldg_Type +
      Latitude +
      Longitude,
    data = ames_train
  ) %>%
    step_log(Gr_Liv_Area, base = 10) %>%
    step_other(Neighborhood, threshold = 0.01) %>%
    step_dummy(all_nominal_predictors()) %>%
    step_interact(~ Gr_Liv_Area:starts_with("Bldg_Type_")) %>%
    step_ns(Latitude, Longitude, deg_free = df)

  workflow() %>% add_model(lm_model) %>% add_recipe(rec)
}

dfs <- c(5, 20, 50)
spline_results <- purrr::map_dfr(dfs, function(df) {
  wf <- make_spline_wflow(df)
  fit <- fit(wf, ames_train)
  predict(fit, ames_test) %>%
    bind_cols(ames_test %>% select(Sale_Price)) %>%
    rmse(truth = Sale_Price, estimate = .pred) %>%
    mutate(deg_free = df)
})

spline_results %>%
  select(deg_free, .metric, .estimate) %>%
  arrange(.estimate)
