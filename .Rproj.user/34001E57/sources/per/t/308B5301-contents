# Exercises

## Exercise 1 — Understanding `step_other()`

Modify the threshold in `step_other(Neighborhood, threshold = ...)` to
0.05 (5%) instead of 1%. Refit the workflow.

a.  How many neighborhoods are now retained (not pooled into "other")?
    Use `tidy()` to find out.
b.  How does this change the number of predictor columns in the final
    model? (Hint: use `extract_fit_parsnip() %>% tidy()` and count rows.)
c.  Does test-set RMSE improve or worsen? What does this suggest about
    the 1% threshold choice?

```{r ex1-solution}
#| code-fold: true
#| code-summary: "Show solution"
#| eval: false
#| echo: false
# Refit with 5% threshold
ames_rec_5pct <-
  recipe(
    Sale_Price ~ Neighborhood +
      Gr_Liv_Area +
      Year_Built +
      Bldg_Type +
      Latitude +
      Longitude,
    data = ames_train
  ) %>%
  step_log(Gr_Liv_Area, base = 10) %>%
  step_other(Neighborhood, threshold = 0.05, id = "nbhd_5pct") %>%
  step_dummy(all_nominal_predictors()) %>%
  step_interact(~ Gr_Liv_Area:starts_with("Bldg_Type_")) %>%
  step_ns(Latitude, Longitude, deg_free = 20)

fit_5pct <- workflow() %>%
  add_model(lm_model) %>%
  add_recipe(ames_rec_5pct) %>%
  fit(ames_train)

# a) Retained neighborhoods
tidy(extract_recipe(fit_5pct, estimated = TRUE), id = "nbhd_5pct") %>%
  nrow() %>%
  cat("Retained neighborhoods at 5% threshold:", ., "\n")

# b) Number of model coefficients
n_coef <- extract_fit_parsnip(fit_5pct) %>% tidy() %>% nrow()
cat("Model coefficients:", n_coef, "\n")

# c) RMSE comparison
rmse_5pct <- predict(fit_5pct, ames_test) %>%
  bind_cols(ames_test %>% select(Sale_Price)) %>%
  rmse(truth = Sale_Price, estimate = .pred)

rmse_1pct <- predict(lm_fit, ames_test) %>%
  bind_cols(ames_test %>% select(Sale_Price)) %>%
  rmse(truth = Sale_Price, estimate = .pred)

bind_rows(
  rmse_1pct %>% mutate(threshold = "1%"),
  rmse_5pct %>% mutate(threshold = "5%")
) %>%
  select(threshold, .metric, .estimate)
```

